# Build/output artifacts
output/
build/

# Generated validator reports (committed baselines live in tests/baselines/)
validation_report_*/
validation_report/

# Python
__pycache__/
*.pyc
.venv/
logs_*.log

# S85+ session render logs + per-session output dirs (cloud_bake)
*.log
output_*/
